{
  "name": "assess",
  "private": true,
  "type": "module",
  "description": "Judge a codebase against what it SHOULD be: derive intent, run the assessment engine across every area, and emit a gap-graph (assessment-graph.json) rendered on an interactive dashboard. Maps intent→code, code→intent, and baseline→code gaps. Never edits your code.",
  "license": "MIT",
  "author": "Boim L",
  "keywords": [
    "codebase-assessment",
    "gap-analysis",
    "intent-vs-code",
    "knowledge-graph",
    "assessment-engine",
    "grounding",
    "dashboard",
    "claude-plugin"
  ],
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev:dashboard": "pnpm --filter @assess/dashboard dev",
    "validate:sample": "node packages/core/scripts/validate-graph.cjs packages/dashboard/public/assessment-graph.json",
    "test:fixtures": "node packages/core/test/run-fixtures.cjs && node packages/core/test/fingerprint-normalization.cjs",
    "test:mcp": "node plugins/assess/mcp/test/mcp-contract.cjs",
    "test:framework": "node packages/core/test/framework-packs.cjs",
    "test:e2e": "node packages/core/runtime/assess-run.mjs --repo packages/core/src --intent examples/intent/assess-core.intent.json --out .assessment",
    "test": "pnpm test:fixtures && pnpm test:adapter && pnpm test:framework && pnpm test:review && pnpm test:dashboard && pnpm validate:sample && pnpm test:e2e && pnpm test:mcp",
    "ci:smoke": "pnpm test:fixtures && pnpm test:adapter && pnpm test:framework && pnpm test:review && pnpm test:dashboard && pnpm validate:sample && pnpm test:e2e && pnpm test:mcp",
    "review:init": "node packages/core/runtime/review-run.mjs init",
    "review:apply": "node packages/core/runtime/review-run.mjs apply",
    "review:validate": "node packages/core/runtime/review-run.mjs validate",
    "test:review": "node packages/core/test/review-decision-fixtures.cjs",
    "test:adapter": "node packages/core/test/adapter-boundary-fixtures.cjs && node packages/core/test/multilanguage-adapters.cjs",
    "test:dashboard": "node packages/dashboard/test/review-readiness.cjs"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.10.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mibrohimsulaeman-a11y/assess.git"
  },
  "bugs": {
    "url": "https://github.com/mibrohimsulaeman-a11y/assess/issues"
  },
  "homepage": "https://github.com/mibrohimsulaeman-a11y/assess#readme"
}
